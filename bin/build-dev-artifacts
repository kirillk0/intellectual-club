#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
SERVER_DIR="${REPO_ROOT}/server"
NATIVE_DIR="${REPO_ROOT}/native_tools"
BUILD_DIR="${REPO_ROOT}/build/dev"
RELEASE_SRC="${SERVER_DIR}/_build/prod/rel/intellectual_club"
RELEASE_DEST="${BUILD_DIR}/intellectual_club"
BIN_DEST="${BUILD_DIR}/bin"

mkdir -p "${BUILD_DIR}" "${BIN_DEST}"

copy_binary() {
  local source="$1"
  local destination="$2"
  local tmp

  tmp="$(mktemp "${destination}.XXXXXX")"
  cp "${source}" "${tmp}"
  chmod 755 "${tmp}"
  mv "${tmp}" "${destination}"
}

pushd "${SERVER_DIR}" >/dev/null
MIX_ENV=prod mix deps.get --only prod
MIX_ENV=prod mix assets.deploy
MIX_ENV=prod mix release --overwrite
popd >/dev/null

cargo build --manifest-path "${NATIVE_DIR}/Cargo.toml" --release --locked

rm -rf "${RELEASE_DEST}"
cp -R "${RELEASE_SRC}" "${RELEASE_DEST}"

for binary in intellectual-club-launcher openai-oauth outlet-shell-daemon outlet-shell-desktop; do
  copy_binary "${NATIVE_DIR}/target/release/${binary}" "${BIN_DEST}/${binary}"
done

cat > "${BUILD_DIR}/manifest.json" <<EOF
{
  "version": 1,
  "created_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "release": "intellectual_club",
  "binaries": [
    "bin/intellectual-club-launcher",
    "bin/openai-oauth",
    "bin/outlet-shell-daemon",
    "bin/outlet-shell-desktop"
  ],
  "postgresql_version": "=16.13.0"
}
EOF

printf 'Built dev artifacts in %s\n' "${BUILD_DIR}"
