<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="theme-color" content="#ffffff" />
    <%= if assigns[:spa] do %>
      <meta name="apple-mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-title" content="Intellectual Club" />
      <meta name="apple-mobile-web-app-status-bar-style" content="default" />
      <link rel="manifest" href={~p"/manifest.webmanifest"} />
      <link rel="apple-touch-icon" href={~p"/apple-touch-icon.png"} />
    <% end %>
    <.live_title default="Intellectual Club">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" type="image/png" sizes="128x128" href={~p"/favicon.png"} />
    <link phx-track-static rel="stylesheet" href={tracked_asset_path(~p"/assets/css/app.css")} />
    <%= if assigns[:spa] do %>
      <link
        phx-track-static
        rel="stylesheet"
        href={tracked_asset_path(~p"/assets/css/spa.css")}
      />
    <% end %>
    <%= unless assigns[:spa] do %>
      <script
        defer
        phx-track-static
        type="text/javascript"
        src={tracked_asset_path(~p"/assets/js/app.js")}
      >
      </script>
    <% end %>
    <%= if assigns[:spa] do %>
      <script
        phx-track-static
        type="module"
        src={tracked_asset_path(~p"/assets/js/spa.js")}
      >
      </script>
    <% end %>
  </head>
  <body class={unless assigns[:spa], do: "min-h-screen bg-zinc-50 text-zinc-900 antialiased"}>
    {@inner_content}
  </body>
</html>
