# Outlet runner settings (required)
OUTLET_SERVER_URL=http://host.docker.internal:8002

# Optional: set a token manually, or leave it empty to use browser pairing flow.
OUTLET_TOKEN=

# Persist the token inside the compose volume (recommended)
OUTLET_CONFIG_DIR=/data

# Optional tuning
OUTLET_RUNNER_ID=
OUTLET_MAX_CONCURRENCY=20
OUTLET_POLL_MAX_WAIT_SECONDS=25
OUTLET_POLL_CHECK_INTERVAL_SECONDS=1
